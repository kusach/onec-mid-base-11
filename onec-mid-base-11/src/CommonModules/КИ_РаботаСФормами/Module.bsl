#Область ПрограммныйИнтерфейс

Процедура ДополнитьФорму(Форма) Экспорт
    
ИмяФормы = Форма.ИмяФормы;

Если ИмяФормы = "Документ.ЗаказПокупателя.Форма.ФормаДокумента" Тогда
    // Здесь добавляем и контакт, и скидку, и кнопку (полный набор)
    ВставитьПолеКонтактноеЛицоИОстальное(Форма);

ИначеЕсли ИмяФормы = "Документ.ПоступлениеТоваровУслуг.Форма.ФормаДокумента" 
    ИЛИ ИмяФормы = "Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента"
	ИЛИ ИмяФормы = "Документ.ОплатаПоставщику.Форма.ФормаДокумента"
    ИЛИ ИмяФормы = "Документ.ОплатаОтПокупателя.Форма.ФормаДокумента" Тогда
    
    // Для этих документов добавляем только поле "Контактное лицо"
    // Используем поиск родителя, чтобы код не падал, если группы "ГруппаШапкаПраво" нет
    ЭлементЯкорь = Форма.Элементы.Найти("Договор");
    Родитель = ?(ЭлементЯкорь <> Неопределено, ЭлементЯкорь.Родитель, Форма);
    
    ВставитьПолеКонтактноеЛицо(Форма, Родитель);

КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ВставитьПолеКонтактноеЛицо(Форма, ЭлементРодитель)
    
  
    ПолеВвода = Форма.Элементы.Добавить("КонтактноеЛицо", Тип("ПолеФормы"), ЭлементРодитель);
    ПолеВвода.Вид = ВидПоляФормы.ПолеВвода;
    ПолеВвода.ПутьКДанным = "Объект.КонтактноеЛицо";
    
    // Программная настройка связи параметров выбора по Владельцу (Контрагенту)
    МассивСвязей = Новый Массив;
    МассивСвязей.Добавить(Новый СвязьПараметраВыбора("Отбор.Владелец", "Объект.Контрагент"));
    ПолеВвода.СвязиПараметровВыбора = Новый ФиксированныйМассив(МассивСвязей);
 

КонецПроцедуры

Процедура ВставитьПолеКонтактноеЛицоИОстальное(Форма)
    
    
    // Ищем элемент "Договор", чтобы добавить новые поля в ту же группу (по ТЗ)
    ЭлементДоговор = Форма.Элементы.Найти("Договор");
    
    // Если договор найден, берем его группу-родителя. Иначе добавляем в корень формы.
    Если ЭлементДоговор <> Неопределено Тогда
        РодительПолей = ЭлементДоговор.Родитель;
    Иначе
        РодительПолей = Форма;
    КонецЕсли;
    
    // 1. Добавляем Контактное лицо
    ПолеКонтакт = Форма.Элементы.Добавить("КонтактноеЛицо", Тип("ПолеФормы"), РодительПолей);
    ПолеКонтакт.Вид = ВидПоляФормы.ПолеВвода;
    ПолеКонтакт.ПутьКДанным = "Объект.КонтактноеЛицо";
    
    МассивСвязей = Новый Массив;
    МассивСвязей.Добавить(Новый СвязьПараметраВыбора("Отбор.Владелец", "Объект.Контрагент"));
    ПолеКонтакт.СвязиПараметровВыбора = Новый ФиксированныйМассив(МассивСвязей);
    
    // 2. Добавляем Согласованную скидку
    ПолеСкидка = Форма.Элементы.Добавить("СогласованнаяСкидка", Тип("ПолеФормы"), РодительПолей);
    ПолеСкидка.Вид = ВидПоляФормы.ПолеВвода;
    ПолеСкидка.ПутьКДанным = "Объект.СогласованнаяСкидка";
    // Привязываем обработчик события
    ПолеСкидка.УстановитьДействие("ПриИзменении", "СогласованнаяСкидкаПриИзменении");
    
    // 3. Добавляем команду и кнопку пересчета
    КомандаПересчета = Форма.Команды.Добавить("ПересчитатьСУчетомСкидки");
    КомандаПересчета.Действие = "ПересчитатьТаблицы";
    КомандаПересчета.Заголовок = "Пересчитать таблицы";
    
    КнопкаПересчета = Форма.Элементы.Добавить("КнопкаПересчетаСУчетомСкидки", Тип("КнопкаФормы"), РодительПолей);
    КнопкаПересчета.Вид = ВидКнопкиФормы.ОбычнаяКнопка;
    КнопкаПересчета.ИмяКоманды = "ПересчитатьСУчетомСкидки";
    
    
КонецПроцедуры
#КонецОбласти